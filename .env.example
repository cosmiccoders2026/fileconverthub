# FileConvertHub Environment Variables

# Public app URL (used for metadata, sitemap, canonical URLs)
NEXT_PUBLIC_APP_URL=https://fileconverthub.com

# Email (optional — contact form falls back to mailto without this)
RESEND_API_KEY=

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=

# Google AdSense (optional)
# NEXT_PUBLIC_ADSENSE_ID=
